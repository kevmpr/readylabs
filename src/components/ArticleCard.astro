---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author: string;
  week: number;
  theme: string;
  isLocked: boolean;
}

const { title, description, pubDate, author, week, theme, isLocked } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('es-AR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
  timeZone: 'UTC',
});

// Theme emojis
const themeEmoji: Record<string, string> = {
  'Costos': '💰',
  'Gobernanza': '🛡️',
};
const emoji = themeEmoji[theme] || '📄';

// Author profile photos
const authorPhotos: Record<string, string> = {
  'Kevin': '/images/imgProfileKevinPalma.png',
  'Santiago': '/images/imgProfileSantiagoDaRos.png',
  'Ignacio': '/images/imgProfileIgnacioMiste.png',
};
const authorPhoto = authorPhotos[author];

// Per-author accent colors
const authorColors: Record<string, { shadow: string; border: string; badge: string; titleHover: string; ring: string; glow: string }> = {
  'Kevin': {
    shadow: 'hover:shadow-spring/15',
    border: 'hover:border-spring/40 dark:hover:border-spring/40',
    badge: 'bg-gradient-to-r from-spring/20 to-azure/20 dark:from-spring/30 dark:to-azure/30 text-spring-dark dark:text-spring-light',
    titleHover: 'group-hover:text-spring dark:group-hover:text-spring-light',
    ring: 'ring-spring/40 dark:ring-spring/30',
    glow: 'from-spring/5 to-azure/5',
  },
  'Santiago': {
    shadow: 'hover:shadow-violet/15',
    border: 'hover:border-violet/40 dark:hover:border-violet/40',
    badge: 'bg-gradient-to-r from-violet/20 to-violet-light/20 dark:from-violet/30 dark:to-violet-light/30 text-violet dark:text-violet-light',
    titleHover: 'group-hover:text-violet dark:group-hover:text-violet-light',
    ring: 'ring-violet/40 dark:ring-violet/30',
    glow: 'from-violet/5 to-violet-light/5',
  },
  'Ignacio': {
    shadow: 'hover:shadow-orange/15',
    border: 'hover:border-orange/40 dark:hover:border-orange/40',
    badge: 'bg-gradient-to-r from-orange/20 to-orange-light/20 dark:from-orange/30 dark:to-orange-light/30 text-orange dark:text-orange-light',
    titleHover: 'group-hover:text-orange dark:group-hover:text-orange-light',
    ring: 'ring-orange/40 dark:ring-orange/30',
    glow: 'from-orange/5 to-orange-light/5',
  },
};
const colors = authorColors[author] || authorColors['Kevin'];
---

<div class:list={[
  'group relative rounded-2xl transition-all duration-500 h-full',
  isLocked ? 'opacity-60 hover:animate-shake' : `hover:-translate-y-2 hover:shadow-2xl ${colors.shadow}`,
]}>
  <div class:list={[
    'relative flex flex-col h-full p-6 rounded-2xl border overflow-hidden transition-all duration-300',
    isLocked
      ? 'bg-gray-100 dark:bg-lab-gray/30 border-gray-200 dark:border-lab-gray-light/30 grayscale'
      : `bg-white dark:bg-lab-gray/60 border-gray-200 dark:border-white/8 backdrop-blur-md ${colors.border}`,
  ]}>
    <!-- Header: Semana + Temática -->
    <div class="flex items-center justify-between mb-4">
      <span class:list={[
        'inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold',
        isLocked
          ? 'bg-gray-200 dark:bg-lab-gray-light text-gray-400 dark:text-lab-text-muted'
          : colors.badge,
      ]}>
        📅 Semana {week}
      </span>

      <span class:list={[
        'inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold border',
        isLocked
          ? 'bg-gray-200 dark:bg-lab-gray-light/50 text-gray-400 dark:text-lab-text-muted border-gray-300 dark:border-lab-gray-lighter/30'
          : 'bg-azure/10 text-azure-dark dark:text-azure-light border-azure/20 dark:border-azure/30',
      ]}>
        {emoji} {theme}
      </span>
    </div>

    <!-- Body: Title + Description -->
    <div class="flex-1">
      <h3 class:list={[
        'text-lg font-bold mb-2 transition-colors duration-300',
        isLocked ? 'text-gray-400 dark:text-lab-text-muted' : `text-gray-900 dark:text-lab-text ${colors.titleHover}`,
      ]}>
        {isLocked ? '🔒 ' : ''}{title}
      </h3>

      <p class="text-sm text-gray-500 dark:text-lab-text-muted leading-relaxed mb-4 line-clamp-3">
        {isLocked ? 'Nivel Bloqueado — Próximamente' : description}
      </p>
    </div>

    <!-- Footer: Author photo + name + Date -->
    <div class="flex items-center justify-between text-xs text-gray-400 dark:text-lab-text-muted pt-4 border-t border-gray-100 dark:border-lab-gray-light/20">
      <span class="flex items-center gap-2">
        {authorPhoto ? (
          <img
            src={authorPhoto}
            alt={author}
            class:list={[
              'w-6 h-6 rounded-full object-cover ring-1',
              isLocked ? 'ring-gray-300 dark:ring-lab-gray-lighter' : colors.ring
            ]}
          />
        ) : (
          <span class:list={[
            'w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-bold',
            isLocked ? 'bg-gray-200 dark:bg-lab-gray-light text-gray-400' : colors.badge
          ]}>
            {author.charAt(0)}
          </span>
        )}
        <span class="font-medium">{author}</span>
      </span>
      <span>{formattedDate}</span>
    </div>

    <!-- Lock overlay for locked cards -->
    {isLocked && (
      <div class="absolute inset-0 rounded-2xl flex items-center justify-center pointer-events-none">
        <div class="absolute inset-0 bg-gray-500/5 dark:bg-black/10 rounded-2xl"></div>
      </div>
    )}

    <!-- Hover glow + shine effect for unlocked -->
    {!isLocked && (
      <div class="absolute inset-0 rounded-2xl overflow-hidden pointer-events-none">
        <!-- Gradient glow -->
        <div class:list={['absolute inset-0 bg-gradient-to-br opacity-0 group-hover:opacity-100 transition-opacity duration-500', colors.glow]}></div>
        <!-- Shine sweep -->
        <div class="absolute inset-0 -translate-x-full group-hover:translate-x-full transition-transform duration-700 ease-in-out bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
      </div>
    )}
  </div>
</div>

<style>
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    10% { transform: translateX(-3px) rotate(-0.5deg); }
    20% { transform: translateX(3px) rotate(0.5deg); }
    30% { transform: translateX(-3px) rotate(-0.5deg); }
    40% { transform: translateX(3px) rotate(0.5deg); }
    50% { transform: translateX(-2px) rotate(-0.3deg); }
    60% { transform: translateX(2px) rotate(0.3deg); }
    70% { transform: translateX(-1px); }
    80% { transform: translateX(1px); }
    90% { transform: translateX(0); }
  }
  .hover\:animate-shake:hover {
    animation: shake 0.6s ease-in-out;
  }
</style>
