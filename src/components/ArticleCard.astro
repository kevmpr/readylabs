---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author: string;
  type: 'edu' | 'story';
  isLocked: boolean;
  level: number;
}

const { title, description, pubDate, author, type, isLocked, level } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('es-AR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const typeLabel = type === 'edu' ? 'Educativo' : 'Storytelling';
const typeIcon = type === 'edu' ? '📘' : '📖';
---

<div class:list={[
  'group relative rounded-2xl transition-all duration-500',
  isLocked ? 'opacity-60' : 'hover:-translate-y-1 hover:shadow-xl hover:shadow-spring/10',
]}>
  <div class:list={[
    'relative p-6 rounded-2xl border overflow-hidden transition-colors duration-300',
    isLocked
      ? 'bg-gray-100 dark:bg-lab-gray/30 border-gray-200 dark:border-lab-gray-light/30 grayscale'
      : 'bg-white dark:bg-lab-gray/60 border-gray-200 dark:border-white/8 backdrop-blur-md hover:border-spring/40 dark:hover:border-spring/40',
  ]}>
    <!-- Level badge -->
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center gap-2">
        <span class:list={[
          'flex items-center justify-center w-8 h-8 rounded-lg text-xs font-bold',
          isLocked ? 'bg-gray-200 dark:bg-lab-gray-light text-gray-400 dark:text-lab-text-muted' : 'bg-gradient-to-br from-spring to-azure text-white'
        ]}>
          {level.toString().padStart(2, '0')}
        </span>
        <span class="text-xs text-gray-400 dark:text-lab-text-muted font-medium">Nivel {level}</span>
      </div>

      {!isLocked && (
        <span class:list={[
          'inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold border',
          type === 'edu'
            ? 'bg-azure/10 text-azure-dark dark:text-azure-light border-azure/20 dark:border-azure/30'
            : 'bg-rosa/10 text-rosa-dark dark:text-rosa-light border-rosa/20 dark:border-rosa/30'
        ]}>
          <span>{typeIcon}</span>
          {typeLabel}
        </span>
      )}

      {isLocked && (
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-gray-200 dark:bg-lab-gray-light/50 text-gray-400 dark:text-lab-text-muted border border-gray-300 dark:border-lab-gray-lighter/30">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="11" x="3" y="11" rx="2" ry="2"></rect>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
          </svg>
          Bloqueado
        </span>
      )}
    </div>

    <!-- Content -->
    <h3 class:list={[
      'text-lg font-bold mb-2 transition-colors',
      isLocked ? 'text-gray-400 dark:text-lab-text-muted' : 'text-gray-900 dark:text-lab-text group-hover:text-spring dark:group-hover:text-spring-light',
    ]}>
      {isLocked ? '🔒 ' : ''}{title}
    </h3>

    <p class="text-sm text-gray-500 dark:text-lab-text-muted leading-relaxed mb-4 line-clamp-2">
      {isLocked ? `Nivel Bloqueado — Disponible el ${formattedDate}` : description}
    </p>

    <!-- Footer -->
    <div class="flex items-center justify-between text-xs text-gray-400 dark:text-lab-text-muted">
      <span class="flex items-center gap-1.5">
        <span class:list={[
          'w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold',
          isLocked ? 'bg-gray-200 dark:bg-lab-gray-light text-gray-400' : 'bg-spring/20 dark:bg-spring/30 text-spring dark:text-spring-light'
        ]}>
          {author.charAt(0)}
        </span>
        {author}
      </span>
      <span>{formattedDate}</span>
    </div>

    <!-- Hover glow for unlocked -->
    {!isLocked && (
      <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-spring/5 to-azure/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
    )}
  </div>
</div>
