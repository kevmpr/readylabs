---
---
<section id="webinar" class="relative py-24 sm:py-32 px-6 bg-white dark:bg-lab-dark transition-colors duration-300">
  <div class="max-w-5xl mx-auto">
    <div class="relative rounded-3xl overflow-hidden shadow-2xl dark:shadow-azure/5">
      
      <!-- Animated Background Layer -->
      <div class="absolute inset-0 z-0 bg-gray-50 dark:bg-lab-gray/80 transition-colors duration-500">
        <!-- Aurora Blobs -->
        <div class="absolute top-0 -left-10 w-96 h-96 bg-azure/30 dark:bg-azure/20 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-[100px] opacity-70 animate-blob"></div>
        <div class="absolute top-0 -right-10 w-96 h-96 bg-spring/30 dark:bg-spring/20 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-[100px] opacity-70 animate-blob animation-delay-2000"></div>
        <div class="absolute -bottom-32 left-1/2 -translate-x-1/2 w-96 h-96 bg-rosa/30 dark:bg-rosa/20 rounded-full mix-blend-multiply dark:mix-blend-screen filter blur-[100px] opacity-70 animate-blob animation-delay-4000"></div>
      </div>

      <!-- Glass Overlay -->
      <div class="absolute inset-0 z-0 bg-white/40 dark:bg-lab-dark/60 backdrop-blur-[2px] border border-white/60 dark:border-white/10 transition-colors duration-500"></div>

      <!-- Content -->
      <div class="relative z-10 p-8 sm:p-14 lg:p-20 text-center">
        <!-- Badge -->
        <span class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-white/60 dark:bg-white/5 backdrop-blur-md text-sm font-bold text-azure-dark dark:text-azure-light mb-8 border border-white/80 dark:border-white/10 shadow-sm transition-colors duration-300">
          <span class="w-2.5 h-2.5 rounded-full bg-spring animate-pulse shadow-[0_0_8px_rgba(34,197,94,0.6)]"></span>
          Evento del Mes
        </span>

        <h2 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-gray-900 dark:text-white mb-6 tracking-tight transition-colors duration-300">
          Cloud Architecture <span class="font-strokey font-normal tracking-wide text-[1.1em] bg-gradient-to-r from-spring to-azure bg-clip-text text-transparent drop-shadow-sm dark:drop-shadow-[0_0_15px_rgba(56,189,248,0.3)] align-middle">Live Session</span>
        </h2>

        <p class="text-gray-600 dark:text-white/70 text-lg max-w-2xl mx-auto mb-12 leading-relaxed transition-colors duration-300">
          Una sesión en vivo donde diseñamos arquitectura cloud desde cero, respondemos preguntas y compartimos experiencias del mundo real.
        </p>

        <!-- Countdown -->
        <div class="flex justify-center gap-6 sm:gap-10 mb-14">
          <div class="flex flex-col items-center">
            <span id="cd-days" class="text-3xl sm:text-4xl lg:text-5xl font-black text-gray-900 dark:text-white tabular-nums tracking-tighter drop-shadow-md">00</span>
            <span class="text-xs sm:text-sm font-semibold text-gray-500 dark:text-white/50 mt-2 uppercase tracking-widest">Días</span>
          </div>
          <span class="text-3xl sm:text-4xl lg:text-5xl font-light text-gray-300 dark:text-white/20 self-start mt-[-4px]">:</span>
          <div class="flex flex-col items-center">
            <span id="cd-hours" class="text-3xl sm:text-4xl lg:text-5xl font-black text-gray-900 dark:text-white tabular-nums tracking-tighter drop-shadow-md">00</span>
            <span class="text-xs sm:text-sm font-semibold text-gray-500 dark:text-white/50 mt-2 uppercase tracking-widest">Horas</span>
          </div>
          <span class="text-3xl sm:text-4xl lg:text-5xl font-light text-gray-300 dark:text-white/20 self-start mt-[-4px]">:</span>
          <div class="flex flex-col items-center">
            <span id="cd-mins" class="text-3xl sm:text-4xl lg:text-5xl font-black text-gray-900 dark:text-white tabular-nums tracking-tighter drop-shadow-md">00</span>
            <span class="text-xs sm:text-sm font-semibold text-gray-500 dark:text-white/50 mt-2 uppercase tracking-widest">Min</span>
          </div>
          <span class="text-3xl sm:text-4xl lg:text-5xl font-light text-gray-300 dark:text-white/20 self-start mt-[-4px]">:</span>
          <div class="flex flex-col items-center">
            <span id="cd-secs" class="text-3xl sm:text-4xl lg:text-5xl font-black text-azure tabular-nums tracking-tighter drop-shadow-md">00</span>
            <span class="text-xs sm:text-sm font-semibold text-azure/70 dark:text-azure/50 mt-2 uppercase tracking-widest">Seg</span>
          </div>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-5">
          <a
            href="https://www.microsoft.com/en-us/microsoft-teams/group-chat-software"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-3 px-8 py-4 rounded-xl font-bold text-gray-700 dark:text-white bg-white/80 dark:bg-lab-gray/80 backdrop-blur-md hover:bg-white dark:hover:bg-lab-gray transition-all duration-300 hover:scale-105 hover:-translate-y-1 shadow-lg hover:shadow-xl border border-gray-200 dark:border-white/10 hover:border-[#6264A7]/50 dark:hover:border-[#6264A7]/50"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 transition-transform group-hover:scale-110" viewBox="0 0 24 24">
              <path fill="#6264A7" d="M11.5 2a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9zm7 3a3 3 0 1 0 0 6 3 3 0 0 0 0-6zm-7 7c-3.038 0-9 1.519-9 4.5V19a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1v-2.5c0-2.981-5.962-4.5-9-4.5zm9.5 0c-.317 0-.67.02-1.047.06A5.49 5.49 0 0 1 22 16.5V19a2.98 2.98 0 0 1-.293 1.277A1 1 0 0 0 22.5 20h.5a1 1 0 0 0 1-1v-2.5c0-2.224-3.376-3.755-6-4.42A11.37 11.37 0 0 1 21 12z"/>
            </svg>
            Microsoft Teams
          </a>
          <a
            href="https://www.youtube.com/@Readymindvideo"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-3 px-8 py-4 rounded-xl font-bold text-gray-700 dark:text-white bg-white/80 dark:bg-lab-gray/80 backdrop-blur-md hover:bg-white dark:hover:bg-lab-gray transition-all duration-300 hover:scale-105 hover:-translate-y-1 shadow-lg hover:shadow-xl border border-gray-200 dark:border-white/10 hover:border-[#FF0000]/50 dark:hover:border-[#FF0000]/50"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 transition-transform group-hover:scale-110" viewBox="0 0 24 24">
              <path fill="#FF0000" d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/>
              <path fill="#FFF" d="M9.545 15.568V8.432L15.818 12z"/>
            </svg>
            Canal de YouTube
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes blob {
    0% { transform: translate(0px, 0px) scale(1); }
    33% { transform: translate(30px, -50px) scale(1.1); }
    66% { transform: translate(-20px, 20px) scale(0.9); }
    100% { transform: translate(0px, 0px) scale(1); }
  }
  .animate-blob {
    animation: blob 8s infinite alternate ease-in-out;
  }
  .animation-delay-2000 {
    animation-delay: 2s;
  }
  .animation-delay-4000 {
    animation-delay: 4s;
  }
</style>

<script is:inline>
  (function() {
    const TOTAL_SECONDS = 12 * 86400 + 8 * 3600 + 45 * 60 + 30;
    let remaining = TOTAL_SECONDS;

    const daysEl = document.getElementById('cd-days');
    const hoursEl = document.getElementById('cd-hours');
    const minsEl = document.getElementById('cd-mins');
    const secsEl = document.getElementById('cd-secs');

    function pad(n) { return String(n).padStart(2, '0'); }

    function update() {
      const d = Math.floor(remaining / 86400);
      const h = Math.floor((remaining % 86400) / 3600);
      const m = Math.floor((remaining % 3600) / 60);
      const s = remaining % 60;

      if (daysEl) daysEl.textContent = pad(d);
      if (hoursEl) hoursEl.textContent = pad(h);
      if (minsEl) minsEl.textContent = pad(m);
      if (secsEl) secsEl.textContent = pad(s);

      remaining--;
      if (remaining < 0) remaining = TOTAL_SECONDS;
    }

    update();
    setInterval(update, 1000);
  })();
</script>
