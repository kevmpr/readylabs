---
---
<section id="webinar" class="relative py-24 sm:py-32 px-6 bg-white dark:bg-lab-dark transition-colors duration-300">
  <div class="max-w-4xl mx-auto">
    <div class="relative rounded-3xl overflow-hidden">
      <!-- Background gradient -->
      <div class="absolute inset-0 bg-gradient-to-br from-violet-dark via-violet to-azure animate-gradient opacity-90"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-black/30 to-transparent"></div>

      <!-- Content -->
      <div class="relative z-10 p-8 sm:p-12 md:p-16 text-center">
        <!-- Badge -->
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/15 backdrop-blur-sm text-sm font-semibold text-white mb-8 border border-white/15">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
          Evento del Mes
        </span>

        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-4 tracking-tight">
          Cloud Architecture <span class="text-azure-light">Live Session</span>
        </h2>

        <p class="text-white/70 text-lg max-w-xl mx-auto mb-10 leading-relaxed">
          Una sesión en vivo donde diseñamos arquitectura cloud desde cero, respondemos preguntas y compartimos experiencias del mundo real.
        </p>

        <!-- Countdown placeholder -->
        <div class="flex justify-center gap-4 sm:gap-6 mb-10">
          <div class="flex flex-col items-center">
            <span class="text-3xl sm:text-4xl font-bold text-white animate-countdown">12</span>
            <span class="text-xs text-white/50 mt-1 uppercase tracking-wider">Días</span>
          </div>
          <span class="text-3xl font-bold text-white/30 self-start">:</span>
          <div class="flex flex-col items-center">
            <span class="text-3xl sm:text-4xl font-bold text-white animate-countdown">08</span>
            <span class="text-xs text-white/50 mt-1 uppercase tracking-wider">Horas</span>
          </div>
          <span class="text-3xl font-bold text-white/30 self-start">:</span>
          <div class="flex flex-col items-center">
            <span class="text-3xl sm:text-4xl font-bold text-white animate-countdown">45</span>
            <span class="text-xs text-white/50 mt-1 uppercase tracking-wider">Min</span>
          </div>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="#"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-white bg-azure hover:bg-azure-light transition-all duration-300 hover:scale-105 shadow-lg shadow-azure/30"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M15 10l4.553-2.276A1 1 0 0 1 21 8.618v6.764a1 1 0 0 1-1.447.894L15 14v-4z"></path>
              <rect width="13" height="10" x="2" y="7" rx="2" ry="2"></rect>
            </svg>
            Microsoft Teams
          </a>
          <a
            href="#"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-white bg-white/15 hover:bg-white/25 border border-white/20 hover:border-white/30 transition-all duration-300 hover:scale-105 backdrop-blur-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="m22 8-6 4 6 4V8Z"></path>
              <rect width="14" height="12" x="2" y="6" rx="2" ry="2"></rect>
            </svg>
            YouTube
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
