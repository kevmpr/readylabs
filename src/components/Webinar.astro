---
---
<section id="webinar" class="relative py-24 sm:py-32 px-6 bg-white dark:bg-lab-dark transition-colors duration-300">
  <div class="max-w-4xl mx-auto">
    <div class="relative rounded-3xl overflow-hidden">
      <!-- Solid background -->
      <div class="absolute inset-0 bg-azure"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-azure-dark/40 to-transparent"></div>

      <!-- Content -->
      <div class="relative z-10 p-8 sm:p-12 md:p-16 text-center">
        <!-- Badge -->
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/15 backdrop-blur-sm text-sm font-semibold text-white mb-8 border border-white/15">
          <span class="w-2 h-2 rounded-full bg-lime animate-pulse"></span>
          Evento del Mes
        </span>

        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-white mb-4 tracking-tight">
          Cloud Architecture <span class="text-spring-light">Live Session</span>
        </h2>

        <p class="text-white/70 text-lg max-w-xl mx-auto mb-10 leading-relaxed">
          Una sesión en vivo donde diseñamos arquitectura cloud desde cero, respondemos preguntas y compartimos experiencias del mundo real.
        </p>

        <!-- Countdown -->
        <div class="flex justify-center gap-4 sm:gap-6 mb-10">
          <div class="flex flex-col items-center">
            <span id="cd-days" class="text-3xl sm:text-4xl font-bold text-white tabular-nums">00</span>
            <span class="text-xs text-white/50 mt-1 uppercase tracking-wider">Días</span>
          </div>
          <span class="text-3xl font-bold text-white/30 self-start">:</span>
          <div class="flex flex-col items-center">
            <span id="cd-hours" class="text-3xl sm:text-4xl font-bold text-white tabular-nums">00</span>
            <span class="text-xs text-white/50 mt-1 uppercase tracking-wider">Horas</span>
          </div>
          <span class="text-3xl font-bold text-white/30 self-start">:</span>
          <div class="flex flex-col items-center">
            <span id="cd-mins" class="text-3xl sm:text-4xl font-bold text-white tabular-nums">00</span>
            <span class="text-xs text-white/50 mt-1 uppercase tracking-wider">Min</span>
          </div>
          <span class="text-3xl font-bold text-white/30 self-start">:</span>
          <div class="flex flex-col items-center">
            <span id="cd-secs" class="text-3xl sm:text-4xl font-bold text-white tabular-nums">00</span>
            <span class="text-xs text-white/50 mt-1 uppercase tracking-wider">Seg</span>
          </div>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="https://www.microsoft.com/en-us/microsoft-teams/group-chat-software"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-azure bg-white hover:bg-white/90 transition-all duration-300 hover:scale-105 shadow-lg shadow-black/20"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24">
              <path fill="#6264A7" d="M11.5 2a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9zm7 3a3 3 0 1 0 0 6 3 3 0 0 0 0-6zm-7 7c-3.038 0-9 1.519-9 4.5V19a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1v-2.5c0-2.981-5.962-4.5-9-4.5zm9.5 0c-.317 0-.67.02-1.047.06A5.49 5.49 0 0 1 22 16.5V19a2.98 2.98 0 0 1-.293 1.277A1 1 0 0 0 22.5 20h.5a1 1 0 0 0 1-1v-2.5c0-2.224-3.376-3.755-6-4.42A11.37 11.37 0 0 1 21 12z"/>
            </svg>
            Microsoft Teams
          </a>
          <a
            href="https://www.youtube.com/@Readymindvideo"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-white bg-white/15 hover:bg-white/25 border border-white/20 hover:border-white/30 transition-all duration-300 hover:scale-105 backdrop-blur-sm"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24">
              <path fill="#FF0000" d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/>
              <path fill="#FFF" d="M9.545 15.568V8.432L15.818 12z"/>
            </svg>
            YouTube
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function() {
    const TOTAL_SECONDS = 12 * 86400 + 8 * 3600 + 45 * 60 + 30;
    let remaining = TOTAL_SECONDS;

    const daysEl = document.getElementById('cd-days');
    const hoursEl = document.getElementById('cd-hours');
    const minsEl = document.getElementById('cd-mins');
    const secsEl = document.getElementById('cd-secs');

    function pad(n) { return String(n).padStart(2, '0'); }

    function update() {
      const d = Math.floor(remaining / 86400);
      const h = Math.floor((remaining % 86400) / 3600);
      const m = Math.floor((remaining % 3600) / 60);
      const s = remaining % 60;

      if (daysEl) daysEl.textContent = pad(d);
      if (hoursEl) hoursEl.textContent = pad(h);
      if (minsEl) minsEl.textContent = pad(m);
      if (secsEl) secsEl.textContent = pad(s);

      remaining--;
      if (remaining < 0) remaining = TOTAL_SECONDS;
    }

    update();
    setInterval(update, 1000);
  })();
</script>
