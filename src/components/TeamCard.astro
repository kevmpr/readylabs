---
interface Props {
  name: string;
  role: string;
  description: string;
  linkedInUrl: string;
  image: string;
  gradient: string;
  glowColor: string;
}

const { name, role, description, linkedInUrl, image, gradient, glowColor } = Astro.props;
---

<div
  class="team-card group relative p-6 rounded-2xl bg-gray-50 dark:bg-lab-gray/60 border border-gray-200 dark:border-white/8 backdrop-blur-md transition-all duration-500 hover:-translate-y-2"
  style={`--glow: ${glowColor};`}
>
  <div class="flex flex-col items-center text-center">
    <!-- Avatar with glow -->
    <div class="relative mb-5">
      <!-- Subtle glow behind the image -->
      <div class:list={[
        'absolute -inset-1 rounded-full opacity-30 blur-sm transition-all duration-500 group-hover:opacity-60 group-hover:blur-md',
        gradient
      ]}></div>
      <!-- Circular photo -->
      <img
        src={image}
        alt={name}
        class="relative w-32 h-32 rounded-full object-cover border-2 border-white/20 dark:border-white/10 transition-transform duration-300 group-hover:scale-105"
      />
    </div>

    <!-- Info -->
    <h3 class="team-card-name text-lg font-bold mb-1 text-gray-900 dark:text-lab-text transition-colors">{name}</h3>
    <span class="text-sm font-medium text-azure dark:text-azure-light mb-3">{role}</span>
    <p class="text-sm text-gray-500 dark:text-lab-text-muted leading-relaxed mb-5">{description}</p>

    <!-- LinkedIn -->
    <a
      href={linkedInUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium text-gray-500 dark:text-lab-text-muted hover:text-azure dark:hover:text-azure-light bg-gray-100 dark:bg-lab-gray-light/50 hover:bg-azure/10 dark:hover:bg-azure/10 border border-gray-200 dark:border-lab-gray-lighter/30 hover:border-azure/30 dark:hover:border-azure/30 transition-all duration-300"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
        <rect width="4" height="12" x="2" y="9"></rect>
        <circle cx="4" cy="4" r="2"></circle>
      </svg>
      LinkedIn
    </a>
  </div>

  <!-- Hover glow overlay -->
  <div class="team-card-glow absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
</div>

<style>
  .team-card:hover {
    border-color: color-mix(in srgb, var(--glow) 40%, transparent);
  }
  .team-card:hover .team-card-name {
    color: var(--glow);
  }
  .team-card-glow {
    background: radial-gradient(ellipse at center, color-mix(in srgb, var(--glow) 8%, transparent), transparent 70%);
  }
</style>
