---
interface Props {
  name: string;
  role: string;
  description: string;
  linkedInUrl: string;
  image: string;
  gradient: string;
  glowColor: string;
}

const { name, role, description, linkedInUrl, image, gradient, glowColor } = Astro.props;
---

<div
  class="team-card group relative p-6 rounded-2xl bg-gray-50 dark:bg-lab-gray/60 border border-gray-200 dark:border-white/8 backdrop-blur-md transition-all duration-500 hover:-translate-y-2 h-full"
  style={`--glow: ${glowColor};`}
>
  <div class="flex flex-col items-center text-center h-full">
    <!-- Avatar with glow -->
    <div class="relative mb-5">
      <!-- Subtle glow behind the image -->
      <div class:list={[
        'absolute -inset-1 rounded-full opacity-30 blur-sm transition-all duration-500 group-hover:opacity-60 group-hover:blur-md',
        gradient
      ]}></div>
      <!-- Circular photo -->
      <img
        src={image}
        alt={name}
        class="relative w-32 h-32 rounded-full object-cover border-2 border-white/20 dark:border-white/10 transition-transform duration-300 group-hover:scale-105"
      />
    </div>

    <!-- Info -->
    <div class="min-h-[3.5rem] flex items-center justify-center w-full mb-1">
      <h3 
        class="team-card-name text-lg font-bold leading-tight text-gray-900 dark:text-lab-text transition-colors"
        set:html={name}
      />
    </div>
    <span class="text-sm font-medium text-azure dark:text-azure-light mb-3">{role}</span>
    <p class="text-sm text-gray-500 dark:text-lab-text-muted leading-relaxed mb-5 flex-1">{description}</p>

    <!-- LinkedIn -->
    <a
      href={linkedInUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium text-gray-500 dark:text-lab-text-muted hover:text-azure dark:hover:text-azure-light bg-gray-100 dark:bg-lab-gray-light/50 hover:bg-azure/10 dark:hover:bg-azure/10 border border-gray-200 dark:border-lab-gray-lighter/30 hover:border-azure/30 dark:hover:border-azure/30 transition-all duration-300"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24">
        <path fill="#0A66C2" class="dark:fill-[#71b7fb]" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.064 2.064 0 1 1 0-4.128 2.064 2.064 0 0 1 0 4.128zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
      LinkedIn
    </a>
  </div>

  <!-- Hover glow overlay -->
  <div class="team-card-glow absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
</div>

<style>
  .team-card:hover {
    border-color: color-mix(in srgb, var(--glow) 40%, transparent);
  }
  .team-card:hover .team-card-name {
    color: var(--glow);
  }
  .team-card-glow {
    background: radial-gradient(ellipse at center, color-mix(in srgb, var(--glow) 8%, transparent), transparent 70%);
  }
</style>
