---
import { getCollection } from 'astro:content';
import ArticleCard from './ArticleCard.astro';

const cutoffDate = new Date('2026-03-09T23:59:59Z');
const allPosts = await getCollection('blog');

const sortedPosts = allPosts.sort(
  (a, b) => new Date(a.data.pubDate).getTime() - new Date(b.data.pubDate).getTime()
);
---

<section id="roadmap" class="relative py-24 sm:py-32 px-6 bg-gray-50 dark:bg-lab-dark transition-colors duration-300" style="background-image: linear-gradient(rgba(15, 255, 111, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(15, 255, 111, 0.03) 1px, transparent 1px); background-size: 60px 60px;">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16 sm:mb-20">
      <span class="inline-block text-sm font-semibold text-azure dark:text-azure-light tracking-widest uppercase mb-4">Artículos LinkedIn</span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight mb-6 text-gray-900 dark:text-lab-text">
        Contenido <span class="text-azure dark:text-azure-light">Semanal</span>
      </h2>
      <p class="text-gray-500 dark:text-lab-text-muted text-lg max-w-2xl mx-auto">
        Cada semana publicamos artículos en LinkedIn sobre temáticas clave del mundo cloud. Desbloquea contenido nuevo cada semana.
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line (mobile) -->
      <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-gradient-to-b from-spring via-azure to-spring/20 lg:hidden"></div>

      <!-- Horizontal line (desktop) -->
      <div class="hidden lg:block absolute top-6 left-0 right-0 h-0.5 bg-gradient-to-r from-spring via-azure to-spring/20"></div>

      <!-- Cards grid -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-6">
        {sortedPosts.map((post) => {
          const isLocked = new Date(post.data.pubDate) > cutoffDate;
          return (
            <div class="relative pl-14 lg:pl-0 lg:pt-14 h-full">
              <!-- Node dot - mobile -->
              <div class:list={[
                'absolute left-4 top-6 w-4 h-4 rounded-full border-2 lg:hidden',
                isLocked ? 'border-gray-300 dark:border-lab-gray-lighter bg-gray-100 dark:bg-lab-gray' : 'border-spring bg-spring'
              ]}></div>

              <!-- Node dot - desktop -->
              <div class:list={[
                'hidden lg:block absolute left-1/2 top-4 -translate-x-1/2 w-4 h-4 rounded-full border-2',
                isLocked ? 'border-gray-300 dark:border-lab-gray-lighter bg-gray-100 dark:bg-lab-gray' : 'border-spring bg-spring'
              ]}></div>

              <ArticleCard
                title={post.data.title}
                description={post.data.description}
                pubDate={new Date(post.data.pubDate)}
                author={post.data.author}
                week={post.data.week}
                theme={post.data.theme}
                isLocked={isLocked}
              />
            </div>
          );
        })}
      </div>
    </div>
  </div>
</section>
