---
---
<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden bg-gray-50 dark:bg-lab-dark transition-colors duration-300" style="background-image: linear-gradient(rgba(124, 58, 237, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(124, 58, 237, 0.03) 1px, transparent 1px); background-size: 60px 60px;">
  <!-- Background gradient orbs -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-violet/10 rounded-full blur-3xl animate-float"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-azure/10 rounded-full blur-3xl animate-float" style="animation-delay: 3s;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-br from-violet/5 to-azure/5 rounded-full blur-3xl"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-5xl mx-auto">
    <!-- Lab badge -->
    <div class="animate-fade-in-up inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/80 dark:bg-lab-gray/60 backdrop-blur-md border border-gray-200 dark:border-white/8 mb-8 transition-colors duration-300">
      <span class="w-2 h-2 rounded-full bg-violet animate-pulse"></span>
      <span class="text-sm font-medium text-gray-500 dark:text-lab-text-muted tracking-wider uppercase">ReadyLabs by Readymind</span>
    </div>

    <!-- Main title -->
    <h1 class="animate-fade-in-up animation-delay-200 text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-tight tracking-tight mb-6 text-gray-900 dark:text-white">
      <span class="block">La tecnología es el código.</span>
      <span class="block mt-2 bg-gradient-to-r from-violet via-azure to-violet bg-clip-text text-transparent animate-gradient">
        Vos sos la mente inquieta.
      </span>
    </h1>

    <!-- Subtitle -->
    <p class="animate-fade-in-up animation-delay-400 text-lg sm:text-xl text-gray-500 dark:text-lab-text-muted max-w-2xl mx-auto mb-10 leading-relaxed">
      Conectando mentes, transformando realidades.
    </p>

    <!-- CTA Button -->
    <div class="animate-fade-in-up animation-delay-600">
      <a
        href="#roadmap"
        class="group relative inline-flex items-center gap-3 px-8 py-4 rounded-xl font-semibold text-white text-lg transition-all duration-300 hover:scale-105 animate-pulse-glow"
      >
        <span class="absolute inset-0 rounded-xl animate-shimmer"></span>
        <span class="relative z-10 flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="5 3 19 12 5 21 5 3"></polygon>
          </svg>
          Iniciar Recorrido
        </span>
      </a>
    </div>

    <!-- Scroll indicator -->
    <div class="mt-20 animate-bounce">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 mx-auto text-gray-300 dark:text-lab-text-muted/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 5v14M19 12l-7 7-7-7"></path>
      </svg>
    </div>
  </div>
</section>
