---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Manifesto from '../components/Manifesto.astro';
import LevelMap from '../components/LevelMap.astro';
import TeamCard from '../components/TeamCard.astro';
import Webinar from '../components/Webinar.astro';

import { Image } from 'astro:assets';
import imgKevin from '../assets/images/imgProfileKevinPalma.png';
import imgSantiago from '../assets/images/imgProfileSantiagoDaRos.png';
import imgIgnacio from '../assets/images/imgProfileIgnacioMiste.png';
import iconReadyLabs from '../assets/images/icon-readylabs.png';
import iconDarkReadyLabs from '../assets/images/icon-dark-readylabs.png';
import iconReadyMind from '../assets/images/icon-readymind.png';
import iconDarkReadyMind from '../assets/images/icon-dark-readymind.png';

const team = [
  {
    name: 'Kevin Maximiliano<br/>Palma Romero',
    role: 'Cloud Azure Platform',
    description: 'Se enfoca en el despliegue de infraestructura, networking y gobierno sobre Azure. Realiza análisis de arquitectura, migraciones y movimientos entre suscripciones, integrando la ejecución técnica con la documentación y el análisis.',
    linkedInUrl: 'https://www.linkedin.com/in/kevin-m-palma-r/',
    image: imgKevin,
    gradient: 'bg-gradient-to-br from-azure to-azure-light',
    glowColor: 'var(--color-azure)',
  },
  {
    name: 'Santiago Lucas<br/>Da Ros',
    role: 'Cloud Demand Hub',
    description: 'Se dedica a la operación técnica en entornos de nube, colaborando en la resolución de incidentes y la creación de laboratorios de prueba. Gestiona la instalación de equipos y herramientas de administración remota.',
    linkedInUrl: 'https://www.linkedin.com/in/santiagodaros/',
    image: imgSantiago,
    gradient: 'bg-gradient-to-br from-violet to-violet-light',
    glowColor: 'var(--color-violet)',
  },
  {
    name: 'Ignacio Agustín<br/>Miste',
    role: 'Cloud Azure Platform',
    description: 'Se encarga de la estandarización y optimización de servicios en Azure y Microsoft 365, implementando políticas de gobierno y modelos de etiquetado. Desarrolla tableros de monitoreo y visibilidad de costos.',
    linkedInUrl: 'https://www.linkedin.com/in/ignacio-miste/',
    image: imgIgnacio,
    gradient: 'bg-gradient-to-br from-orange to-orange-light',
    glowColor: 'var(--color-orange)',
  },
];
---

<Layout>
  <!-- Navigation -->
  <nav class="fixed top-0 left-0 right-0 z-50 px-6 py-4 bg-white/80 dark:bg-lab-dark/80 backdrop-blur-md border-b border-gray-200/50 dark:border-lab-gray-light/30 transition-colors duration-300">
    <div class="max-w-6xl mx-auto flex items-center justify-between">
      <a href="#hero" class="flex items-center gap-2 group">
        <Image src={iconReadyLabs} alt="ReadyLabs" class="h-8 w-auto dark:hidden" />
        <Image src={iconDarkReadyLabs} alt="ReadyLabs" class="h-8 w-auto hidden dark:block" />
      </a>
      <div class="flex items-center gap-6">
        <div class="hidden sm:flex items-center gap-6 text-sm text-gray-600 dark:text-lab-text-muted">
          <a href="#manifesto" class="hover:text-spring dark:hover:text-spring-light transition-colors">Manifiesto</a>
          <a href="#roadmap" class="hover:text-spring dark:hover:text-spring-light transition-colors">Artículos</a>
          <a href="#team" class="hover:text-spring dark:hover:text-spring-light transition-colors">Equipo</a>
          <a href="#webinar" class="hover:text-spring dark:hover:text-spring-light transition-colors">Webinar</a>
        </div>
        <!-- Theme Toggle Button -->
        <button
          onclick="toggleTheme()"
          class="p-2 rounded-xl bg-gray-100 dark:bg-lab-gray-light hover:bg-gray-200 dark:hover:bg-lab-gray-lighter text-gray-600 dark:text-lab-text-muted hover:text-spring dark:hover:text-spring-light transition-all duration-300 cursor-pointer"
          aria-label="Cambiar tema"
        >
          <!-- Moon icon (shown in light mode) -->
          <svg id="moon-icon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
          </svg>
          <!-- Sun icon (shown in dark mode) -->
          <svg id="sun-icon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2"></path>
            <path d="M12 20v2"></path>
            <path d="m4.93 4.93 1.41 1.41"></path>
            <path d="m17.66 17.66 1.41 1.41"></path>
            <path d="M2 12h2"></path>
            <path d="M20 12h2"></path>
            <path d="m6.34 17.66-1.41 1.41"></path>
            <path d="m19.07 4.93-1.41 1.41"></path>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Sections -->
  <main>
    <Hero />
    <Manifesto />
    <LevelMap />

  <!-- Team Section -->
  <section id="team" class="reveal-on-scroll relative py-24 sm:py-32 px-6 bg-white dark:bg-lab-dark transition-colors duration-300">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16 sm:mb-20">
        <span class="inline-block text-sm font-semibold text-spring-dark dark:text-spring tracking-widest uppercase mb-4">El Equipo</span>
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight mb-6 text-gray-900 dark:text-lab-text">
          Los <span class="bg-gradient-to-r from-spring to-azure-light bg-clip-text text-transparent">Arquitectos</span>
        </h2>
        <p class="text-gray-500 dark:text-lab-text-muted text-lg max-w-2xl mx-auto">
          Las mentes detrás de ReadyLabs, comprometidas con construir una comunidad técnica de valor.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        {team.map((member) => (
          <TeamCard {...member} />
        ))}
      </div>
    </div>
  </section>

  <Webinar />
  </main>

  <!-- Footer -->
  <footer class="py-12 px-6 border-t border-gray-200 dark:border-lab-gray-light/30 bg-gray-50 dark:bg-lab-darker transition-colors duration-300">
    <div class="max-w-6xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <Image src={iconReadyLabs} alt="ReadyLabs" class="h-6 w-auto dark:hidden" />
        <Image src={iconDarkReadyLabs} alt="ReadyLabs" class="h-6 w-auto hidden dark:block" />
        <span class="text-gray-400 dark:text-lab-text-muted text-sm">by</span>
        <a href="https://readymind.ms/ar/" target="_blank" rel="noopener noreferrer" class="transition-transform hover:scale-105">
          <Image src={iconReadyMind} alt="Readymind" class="h-5 w-auto dark:hidden" />
          <Image src={iconDarkReadyMind} alt="Readymind" class="h-5 w-auto hidden dark:block" />
        </a>
      </div>
      <p class="text-sm text-gray-500 dark:text-lab-text-muted">
        © 2026 Readymind. Curiosidad sobre certeza.
      </p>
    </div>
  </footer>
</Layout>
